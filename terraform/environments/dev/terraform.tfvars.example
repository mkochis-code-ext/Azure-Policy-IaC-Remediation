# Environment Configuration
environment_prefix = "dev"
workload          = "AzurePolicyDemo"
location          = "eastus"
data_location     = ""  # Defaults to location if not specified

# Tags
tags = {
  Project     = "Azure Policy Sample"
  Owner       = "Platform Team"
  CostCenter  = "Engineering"
}

# Policy Compliance Alert Email Recipients
alert_email_addresses = ["your-email@example.com"]
